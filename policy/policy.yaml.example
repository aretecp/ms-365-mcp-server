# Areté Microsoft 365 MCP Server policy.
#
# Schema:
#   defaults.allow:        list of tools every authenticated user may call
#   users.<upn>.allow:     extra tools allowed for a specific Entra user
#   users.<upn>.deny:      tools explicitly denied for a specific user (wins over allow)
#
# Precedence: user.deny > user.allow > defaults.allow > default-deny.
# Unknown users fall through to defaults.allow.
#
# All write tools are deliberately OFF defaults.allow. Per-user opt-in is the
# point of the policy file: a misconfiguration shouldn't grant blanket send/
# update/delete authority across the tenant. Add a `users.<upn>.allow` block
# for each operator who needs write access.
#
# Reloading:
#   - Edits via the admin UI at /admin/login reload automatically.
#   - Edits to this file on disk are picked up on SIGHUP:
#       kill -HUP $(pidof microsoft-mcp-server)
#   - Parse errors are logged; the previously-loaded policy stays active.
#   - The admin UI is gated by the MS365_MCP_POLICY_ADMINS env var
#     (comma-separated UPNs), independent of this file.

defaults:
  allow:
    # Mail (read)
    - list-mail-messages
    - get-mail-message
    - list-mail-folders
    - list-mail-folder-messages
    - list-mail-attachments

    # Calendar (read)
    - list-calendar-events
    - get-calendar-event
    - get-calendar-view

    # Files / OneDrive (read)
    - get-drive-root-item
    - list-folder-files
    - get-drive-item

    # Identity
    - get-me

    # Users (directory lookup)
    - list-users
    - get-user

    # SharePoint (read)
    - list-sites
    - get-site
    - list-site-drives
    - list-drive-root-children
    - list-drive-folder-children
    - get-drive-item-by-id
    - list-site-lists
    - list-site-list-items

    # Teams (read)
    - list-chats
    - get-chat
    - list-chat-messages
    - get-chat-message
    - list-joined-teams
    - list-team-channels
    - list-channel-messages
    - get-channel-message
    - list-channel-message-replies
    - find-online-meeting
    - get-online-meeting
    - list-meeting-transcripts

    # Utilities
    - download-bytes
    - parse-teams-url

# Example per-user overrides. Keys are Entra userPrincipalNames (case-insensitive).
#
# users:
#   spencer@areteintelligence.com:
#     allow:
#       # Mail drafts (no send — human reviews + sends from Outlook).
#       # See README "Why no Mail.Send".
#       - create-draft-email
#       - update-mail-message
#       - add-mail-attachment
#       - delete-mail-message
#       # Calendar writes
#       - create-calendar-event
#       - update-calendar-event
#       - delete-calendar-event
#       # Teams writes
#       - send-chat-message
#       - send-channel-message
#       - send-channel-message-reply
#       - create-online-meeting
#       - update-online-meeting
#       - delete-online-meeting
#
#   readonly-bot@areteintelligence.com:
#     deny:
#       - download-bytes
