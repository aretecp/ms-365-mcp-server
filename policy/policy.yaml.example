# Areté Microsoft 365 MCP Server policy.
#
# Schema:
#   defaults.allow:        list of tools every authenticated user may call
#   users.<upn>.allow:     extra tools allowed for a specific Entra user
#   users.<upn>.deny:      tools explicitly denied for a specific user (wins over allow)
#   mailSend:              same-domain guard for the mail-draft-send tool (see below)
#
# Precedence: user.deny > user.allow > defaults.allow > default-deny.
# Unknown users fall through to defaults.allow.
#
# All write tools are deliberately OFF defaults.allow. Per-user opt-in is the
# point of the policy file: a misconfiguration shouldn't grant blanket send/
# update/delete authority across the tenant. Add a `users.<upn>.allow` block
# for each operator who needs write access.
#
# Reloading:
#   - Edits via the admin UI at /admin/login reload automatically.
#   - Edits to this file on disk are picked up on SIGHUP:
#       kill -HUP $(pidof microsoft-mcp-server)
#   - Parse errors are logged; the previously-loaded policy stays active.
#   - The admin UI is gated by the MS365_MCP_POLICY_ADMINS env var
#     (comma-separated UPNs), independent of this file.

defaults:
  allow:
    # Mail (read)
    - mail-message-list
    - mail-message-get
    - mail-folder-list
    - mail-attachment-list

    # Calendar (read)
    - calendar-event-get
    - calendar-view

    # Files / OneDrive (read)
    - drive-children-list
    - drive-item-get

    # Identity
    - identity-get-me

    # Users (directory lookup)
    - user-search
    - user-get

    # SharePoint (read)
    - sharepoint-site-list
    - sharepoint-site-get
    - sharepoint-drive-list
    - sharepoint-drive-children-list
    - sharepoint-drive-item-get
    - sharepoint-list-list
    - sharepoint-list-item-list

    # Teams (read)
    - teams-chat-list
    - teams-chat-get
    - teams-chat-message-list
    - teams-chat-message-get
    - teams-joined-list
    - teams-channel-list
    - teams-channel-message-list
    - teams-channel-message-get
    - teams-channel-message-reply-list
    - teams-online-meeting-find
    - teams-meeting-transcript-list

    # Utilities
    - download-bytes
    - parse-teams-url

# Same-domain send guard for the mail-draft-send tool.
#
# mail-draft-send is the ONLY tool that can put mail on the wire (POST
# /me/messages/{id}/send, scope Mail.Send). On top of the normal allow/deny
# gate, the server enforces this guard IN CODE before the send reaches Graph:
# the sender and EVERY recipient (to/cc/bcc) must share one email domain.
#
#   requireSameDomain:  master switch. Default true (and assumed true if this
#                       block is omitted). Set false to disable the guard and
#                       let the per-user allow/deny policy stand alone.
#   allowedDomains:     if non-empty, the shared domain must be one of these,
#                       so even an internal-only message from an unlisted domain
#                       is refused. Empty/omitted => "the sender's own domain".
#                       A leading '@' is optional and case is ignored.
mailSend:
  requireSameDomain: true
  allowedDomains:
    - aretepartners.com

# Example per-user overrides. Keys are Entra userPrincipalNames (case-insensitive).
#
# users:
#   spencer@areteintelligence.com:
#     allow:
#       # Mail drafts.
#       - mail-draft-create
#       - mail-message-update
#       - mail-attachment-add
#       - mail-message-delete
#       # Mail send. Even with this allow, the mailSend same-domain guard above
#       # still applies: the sender + every recipient must be in an allowed
#       # domain or the send is refused in code.
#       - mail-draft-send
#       # Calendar writes
#       - calendar-event-create
#       - calendar-event-update
#       - calendar-event-delete
#       # Teams writes
#       - teams-chat-message-send
#       - teams-channel-message-send
#       - teams-channel-message-reply-send
#       - teams-online-meeting-create
#       - teams-online-meeting-update
#       - teams-online-meeting-delete
#
#   readonly-bot@areteintelligence.com:
#     deny:
#       - download-bytes
